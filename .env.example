# ============================================================
# AI Trainer Hub — 환경변수 예시
# 사용법: cp .env.example .env.local 후 값 입력
# 자세한 발급 방법: API_CONNECTIONS.md 참고
# ============================================================

# ── 필수: NextAuth ───────────────────────────────────────────
# 생성: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-random-32-chars
# 로컬: http://localhost:3000 / 배포: https://YOUR.up.railway.app
NEXTAUTH_URL=http://localhost:3000

# ── OAuth: 카카오 (가장 중요) ─────────────────────────────────
# 발급: https://developers.kakao.com → 앱 추가 → REST API 키
# Redirect URI 등록: /api/auth/callback/kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── OAuth: 네이버 ────────────────────────────────────────────
# 발급: https://developers.naver.com → 애플리케이션 등록
# Redirect URI 등록: /api/auth/callback/naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── OAuth: 구글 ──────────────────────────────────────────────
# 발급: https://console.cloud.google.com → OAuth 2.0 클라이언트
# Redirect URI 등록: /api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI: Anthropic Claude ─────────────────────────────────────
# 발급: https://console.anthropic.com
# 없으면 Mock 모드로 동작 (고정 응답만 표시)
ANTHROPIC_API_KEY=

# ── 데이터베이스: PostgreSQL ─────────────────────────────────
# Railway PostgreSQL 서비스 추가 시 자동 연결됨
# 로컬 테스트 시 비워두면 DB 없이도 동작 가능
DATABASE_URL=postgresql://user:password@localhost:5432/ai_trainer_hub

# ── 음성: ElevenLabs (선택) ──────────────────────────────────
# 발급: https://elevenlabs.io
# 없으면 TTS 기능 비활성화
ELEVENLABS_API_KEY=

# ── 이미지 저장: Cloudinary (선택) ──────────────────────────
# 발급: https://cloudinary.com
# 없으면 이미지가 브라우저 메모리에만 보관됨 (새로고침 시 삭제)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
